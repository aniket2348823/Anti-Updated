# Antigravity V6 — PERFORMANCE-OPTIMIZED Modelfile for Granite 4.0 1.5B (Hybrid)
# Target: i5 11th Gen | 8GB RAM | 2GB GPU
# Optimizations: temperature=0, reduced num_predict, safe thread count (4)
# Run: ollama create antigravity-cortex -f Modelfile.antigravity

FROM granite4:1b-h

# Core Parameters — OPTIMIZED for Speed on i5
PARAMETER num_ctx 2048
PARAMETER num_predict 200
PARAMETER temperature 0
PARAMETER top_p 0.9
PARAMETER repeat_penalty 1.1
PARAMETER num_thread 4

# System Prompt — MINIMAL (saves tokens every call)
SYSTEM """CortexEngine: security analysis AI. Output ONLY the requested format. No explanations. Be deterministic."""
